# Copy this file to .env.local and fill in your own keys.
# All values are exposed to the browser (static export).

# Convex deployment URL – run `npx convex dev` to create a project and get this.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# KLIPY GIF API key – get one at https://partner.klipy.com
NEXT_PUBLIC_KLIPY_API_KEY=your-klipy-api-key
