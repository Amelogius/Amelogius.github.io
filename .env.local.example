# Copy this file to .env.local and fill in your own keys.
# All values are exposed to the browser (static export), so only use public/anon keys.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# KLIPY GIF API key – get one at https://partner.klipy.com
NEXT_PUBLIC_KLIPY_API_KEY=your-klipy-api-key
